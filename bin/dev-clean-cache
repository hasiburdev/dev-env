#!/bin/bash

set -euo pipefail

log() {
    echo -e "\n[INFO] $1"
}

warn() {
    echo -e "\n[WARN] $1"
}

exists() {
    command -v "$1" >/dev/null 2>&1
}

clean_pacman() {
    if exists pacman; then
        log "Cleaning pacman cache"
        sudo pacman -Sc --noconfirm
    fi
}

clean_pnpm() {
    if exists pnpm; then
         log "Cleaning pnpm cache"
        pnpm store prune
    fi
}

clean_npm() {
    if exists npm; then
        log "Cleaning npm cache"
        npm cache clean --force
    fi
}

clean_yarn() {
    if exists yarn; then
        log "Cleaning yarn cache"
        yarn cache clean
    fi
}

clean_deno() {
      if exists deno; then
        log "Cleaning deno cache"
        deno clean
    fi
}

clean_yay() {
    if exists yay; then
        log "Cleaning yay cache"
        yay -Sc --noconfirm --aur
    fi
}


clean_uv() {
    if exists uv; then
        log "Cleaning uv"
        uv cache clean
    fi
}

clean_go() {
    if exists go; then
        log "Cleaning go cache"
        go clean -cache
        go clean -modcache
        go clean -testcache
    fi
}

clean_journal() {
    if exists journalctl; then
        log "Cleaning systemd journal logs"
        sudo journalctl --vacuum-time=7d
    fi
}

clean_docker() {
    if exists docker; then
        log "Cleaning docker cache"
        // TODO: Add docker cleanup commands here
    fi
}

clean_flutter() {
    if exists flutter; then
        log "Cleaning flutter pub cache"
        flutter pub cache clean
    fi
}


main() {
    log "Starting system cleanup..."
    # Arch linux package manager cache
    clean_pacman
    clean_yay

    # System clean up
    clean_journal
    clean_docker

    # NodeJs related cache
    clean_pnpm
    clean_npm
    clean_yarn
    clean_deno
    
    # Python related cache
    clean_uv

    # Golang related cache
    clean_go

    # Flutter related cache
    clean_flutter

}

main "$@"


